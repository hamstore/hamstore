{
  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "esModuleInterop": true,
    "types": ["node", "vitest/globals"],
    "lib": ["ESNext"],
    "removeComments": true,
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "noUncheckedIndexedAccess": true,
    "paths": {
      "~/*": ["*"]
    }
  },
  "exclude": ["./dist"],
  "include": ["./**/*.ts"]
}
