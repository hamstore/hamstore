{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["node", "@docusaurus/module-type-aliases"],
    "baseUrl": ".",
    "composite": true,
    "emitDeclarationOnly": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "removeComments": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "sourceMap": true,
    "target": "es2022",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "preserveSymlinks": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "noFallthroughCasesInSwitch": true
  },
  "references": [
    { "path": "../packages/core/tsconfig.build.json" },
    { "path": "../packages/command-json-schema/tsconfig.build.json" },
    { "path": "../packages/lib-react-visualizer/tsconfig.build.json" },
    { "path": "../demo/blueprint/tsconfig.build.json" }
  ],
  "exclude": ["./dist", ".dependency-cruiser.js"],
  "include": ["."]
}
