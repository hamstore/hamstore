{
  "name": "@hamstore/hamstore",
  "description": "Making Event Sourcing easy 😎",
  "license": "MIT",
  "homepage": "https://github.com/hamstore/hamstore#readme",
  "bugs": "https://github.com/hamstore/hamstore/issues",
  "repository": "hamstore/hamstore.git",
  "keywords": [
    "event",
    "source",
    "store",
    "typescript"
  ],
  "type": "module",
  "scripts": {
    "check-audit": "pnpm audit",
    "graph": "nx dep-graph",
    "package": "nx run-many --target=package --all --parallel=4",
    "postinstall": "husky install && syncpack format",
    "resolve-audit": "pnpm audit --fix",
    "set-packages-versions": "tsx scripts/setPackagesVersions.ts",
    "test": "nx run-many --target=test --all",
    "test-affected": "nx affected --target=test",
    "test-circular": "pnpm depcruise --validate .dependency-cruiser.js .",
    "test-linter": "nx run-many --target=test-linter --all --parallel=4",
    "test-type": "nx run-many --target=test-type --all --parallel=4",
    "test-unit": "nx run-many --target=test-unit --all --parallel=4",
    "watch": "nx run-many --target=watch --all  --parallel=4"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nx/workspace": "^21.5.3",
    "@types/node": "^24.5.2",
    "aws-sdk": "^2.1692.0",
    "dependency-cruiser": "^17.0.1",
    "husky": "^9.1.7",
    "nx": "^21.5.3",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "syncpack": "^14.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": "^22.19.0 || ^24.0.0"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@scarf/scarf",
      "@tree-sitter-grammars/tree-sitter-yaml",
      "aws-sdk",
      "core-js",
      "core-js-pure",
      "cpu-features",
      "es5-ext",
      "esbuild",
      "nx",
      "protobufjs",
      "serverless",
      "ssh2",
      "tree-sitter",
      "tree-sitter-json"
    ]
  }
}
