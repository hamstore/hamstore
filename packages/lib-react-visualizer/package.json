{
  "name": "@hamstore/lib-react-visualizer",
  "description": "React component to visualize, design and manually test Hamstore event stores and commands.",
  "license": "MIT",
  "keywords": [
    "event",
    "source",
    "store",
    "typescript"
  ],
  "homepage": "https://github.com/hamstore/hamstore#readme",
  "bugs": "https://github.com/hamstore/hamstore/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamstore/hamstore.git",
    "directory": "packages/lib-react-visualizer"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/esm/*.mjs",
      "require": "./dist/cjs/*.cjs",
      "default": "./dist/esm/*.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint-fix": "pnpm oxlint --fix",
    "lint-fix-all": "pnpm lint-fix .",
    "package": "tsdown",
    "publish-package": "npm publish --provenance --access public --tag ${NPM_DIST_TAG:-latest}",
    "test": "pnpm test-type && pnpm test-unit && pnpm test-circular && pnpm test-linter",
    "test-circular": "pnpm depcruise --validate .dependency-cruiser.js .",
    "test-linter": "pnpm oxlint .",
    "test-type": "tsc --noEmit --emitDeclarationOnly false",
    "test-unit": "pnpm vitest run --passWithNoTests",
    "watch": "tsdown --watch"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hamstore/event-storage-adapter-redux": "workspace:",
    "@mui/icons-material": "^5.18.0",
    "@mui/lab": "^5.0.0-alpha.177",
    "@mui/material": "^5.18.0",
    "@reduxjs/toolkit": "^1.9.7",
    "@rjsf/core": "^5.24.13",
    "@rjsf/mui": "^5.24.13",
    "@rjsf/utils": "^5.24.13",
    "@rjsf/validator-ajv8": "^5.24.13",
    "react-json-view": "^1.21.3",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@hamstore/command-json-schema": "workspace:",
    "@hamstore/core": "workspace:",
    "@mui/types": "^7.4.12",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "dependency-cruiser": "^17.0.1",
    "json-schema-to-ts": "^3.1.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "react": "^19.1.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@hamstore/command-json-schema": "*",
    "@hamstore/core": "*",
    "react": "^19.0.0"
  }
}
