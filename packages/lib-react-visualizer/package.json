{
  "name": "@hamstore/lib-react-visualizer",
  "description": "React component to visualize, design and manually test Hamstore event stores and commands.",
  "keywords": [
    "event",
    "source",
    "store",
    "typescript"
  ],
  "homepage": "https://github.com/hamstore/hamstore#readme",
  "bugs": "https://github.com/hamstore/hamstore/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamstore/hamstore.git",
    "directory": "packages/lib-react-visualizer"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/esm/*.mjs",
      "require": "./dist/cjs/*.cjs",
      "default": "./dist/esm/*.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint-fix": "pnpm oxlint --fix",
    "lint-fix-all": "pnpm lint-fix .",
    "package": "rm -rf dist && pnpm package-cjs && pnpm package-esm && pnpm package-types",
    "package-cjs": "NODE_ENV=cjs pnpm transpile --out-dir dist/cjs --source-maps --out-file-extension .cjs",
    "package-esm": "NODE_ENV=esm pnpm transpile --out-dir dist/esm --source-maps --out-file-extension .mjs",
    "package-types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "publish-package": "npm publish --provenance --access public --tag ${NPM_DIST_TAG:-latest}",
    "test": "pnpm test-type && pnpm test-unit && pnpm test-circular && pnpm test-linter",
    "test-circular": "pnpm depcruise --validate .dependency-cruiser.js .",
    "test-linter": "pnpm oxlint .",
    "test-type": "tsc --noEmit --emitDeclarationOnly false",
    "test-unit": "pnpm vitest run --passWithNoTests",
    "transpile": "babel src --extensions .ts,.tsx --quiet",
    "watch": "rm -rf dist && concurrently 'pnpm:package-* --watch'"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hamstore/event-storage-adapter-redux": "workspace:",
    "@mui/icons-material": "^5.18.0",
    "@mui/lab": "^5.0.0-alpha.177",
    "@mui/material": "^5.18.0",
    "@reduxjs/toolkit": "^1.9.7",
    "@rjsf/core": "^5.24.13",
    "@rjsf/mui": "^5.24.13",
    "@rjsf/utils": "^5.24.13",
    "@rjsf/validator-ajv8": "^5.24.13",
    "react-json-view": "^1.21.3",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.4",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/plugin-transform-react-constant-elements": "^7.27.1",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@hamstore/command-json-schema": "workspace:",
    "@hamstore/core": "workspace:",
    "@mui/types": "^7.4.12",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "babel-plugin-module-resolver": "^4.1.0",
    "babel-plugin-optimize-clsx": "^2.6.2",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.0.1",
    "json-schema-to-ts": "^3.1.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "react": "^19.1.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@hamstore/command-json-schema": "*",
    "@hamstore/core": "*",
    "react": "^19.0.0"
  }
}
