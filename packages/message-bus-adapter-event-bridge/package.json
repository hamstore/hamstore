{
  "name": "@hamstore/message-bus-adapter-event-bridge",
  "description": "DRY Hamstore MessageBus definition using AWS EventBridge",
  "license": "MIT",
  "homepage": "https://github.com/hamstore/hamstore#readme",
  "bugs": "https://github.com/hamstore/hamstore/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamstore/hamstore.git",
    "directory": "packages/message-bus-adapter-event-bridge"
  },
  "keywords": [
    "event",
    "source",
    "store",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/esm/*.mjs",
      "require": "./dist/cjs/*.cjs",
      "default": "./dist/esm/*.mjs"
    }
  },
  "type": "module",
  "scripts": {
    "lint-fix": "pnpm oxlint --fix",
    "lint-fix-all": "pnpm lint-fix .",
    "package": "rm -rf dist && pnpm package-cjs && pnpm package-esm && pnpm package-types",
    "package-cjs": "NODE_ENV=cjs pnpm transpile --out-dir dist/cjs --source-maps --out-file-extension .cjs",
    "package-esm": "NODE_ENV=esm pnpm transpile --out-dir dist/esm --source-maps --out-file-extension .mjs",
    "package-types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "publish-package": "npm publish --provenance --access public --tag ${NPM_DIST_TAG:-latest}",
    "test": "pnpm test-type && pnpm test-unit && pnpm test-circular && pnpm test-linter",
    "test-circular": "pnpm depcruise --validate .dependency-cruiser.js .",
    "test-linter": "pnpm oxlint .",
    "test-type": "tsc --noEmit --emitDeclarationOnly false",
    "test-unit": "pnpm vitest run --passWithNoTests",
    "transpile": "babel src --extensions .ts --quiet",
    "watch": "rm -rf dist && concurrently 'pnpm:package-* --watch'"
  },
  "dependencies": {
    "@types/aws-lambda": "^8.10.152",
    "lodash.chunk": "^4.2.0"
  },
  "devDependencies": {
    "@aws-sdk/client-eventbridge": "^3.893.0",
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@hamstore/core": "workspace:",
    "@types/lodash.chunk": "^4.2.9",
    "@types/node": "^24.5.2",
    "aws-sdk-client-mock": "^2.2.0",
    "babel-plugin-module-resolver": "^4.1.0",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "ts-node": "^10.9.2",
    "ts-toolbelt": "^9.6.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@aws-sdk/client-eventbridge": "^3.0.0",
    "@hamstore/core": "*"
  }
}
