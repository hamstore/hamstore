{
  "name": "@hamstore/event-type-standard-schema",
  "description": "DRY Hamstore EventType definition using Standard Schema with runtime validation",
  "license": "MIT",
  "keywords": [
    "event",
    "source",
    "standard-schema",
    "store",
    "typescript",
    "validation"
  ],
  "homepage": "https://github.com/hamstore/hamstore#readme",
  "bugs": "https://github.com/hamstore/hamstore/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamstore/hamstore.git",
    "directory": "packages/event-type-standard-schema"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/esm/*.mjs",
      "require": "./dist/cjs/*.cjs",
      "default": "./dist/esm/*.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint-fix": "pnpm oxlint --fix",
    "lint-fix-all": "pnpm lint-fix .",
    "package": "tsdown",
    "publish-package": "npm publish ${NPM_PROVENANCE:+--provenance} --access public --tag ${NPM_DIST_TAG:-latest}",
    "test": "pnpm test-type && pnpm test-unit && pnpm test-circular && pnpm test-linter",
    "test-circular": "pnpm depcruise --validate .dependency-cruiser.js .",
    "test-linter": "pnpm oxlint .",
    "test-type": "tsc --noEmit --emitDeclarationOnly false",
    "test-unit": "pnpm vitest run --passWithNoTests",
    "watch": "tsdown --watch"
  },
  "devDependencies": {
    "@hamstore/core": "workspace:",
    "@standard-schema/spec": "^1.1.0",
    "@types/node": "^24.5.2",
    "dependency-cruiser": "^17.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "ts-toolbelt": "^9.6.0",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@hamstore/core": "*",
    "@standard-schema/spec": "^1.0.0"
  }
}
