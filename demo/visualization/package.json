{
  "name": "@hamstore/demo-visualization",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamstore/hamstore.git",
    "directory": "demo/visualization"
  },
  "scripts": {
    "build": "rm -rf dist && vite build",
    "lint-fix": "pnpm oxlint --fix",
    "lint-fix-all": "pnpm lint-fix .",
    "start": "vite",
    "test": "pnpm test-type && pnpm test-circular && pnpm test-linter",
    "test-circular": "pnpm depcruise --validate .dependency-cruiser.js .",
    "test-linter": "pnpm oxlint .",
    "test-type": "tsc --noEmit --emitDeclarationOnly false"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@hamstore/command-json-schema": "workspace:",
    "@hamstore/core": "workspace:",
    "@hamstore/demo-blueprint": "workspace:",
    "@hamstore/lib-react-visualizer": "workspace:",
    "@mui/material": "^5.18.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "uuid": "^13.0.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.0.3",
    "dependency-cruiser": "^17.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.6",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "type": "module"
}
