{
  "name": "@hamstore/demo-blueprint",
  "license": "MIT",
  "homepage": "https://github.com/hamstore/hamstore#readme",
  "bugs": "https://github.com/hamstore/hamstore/issues",
  "repository": "hamstore/hamstore.git",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "types": "dist/types/index.d.ts",
  "scripts": {
    "lint-fix": "pnpm eslint --fix",
    "lint-fix-all": "pnpm lint-fix .",
    "package": "rm -rf dist && pnpm package-cjs && pnpm package-esm && pnpm package-types",
    "package-cjs": "NODE_ENV=cjs pnpm transpile --out-dir dist/cjs --source-maps --out-file-extension .cjs",
    "package-esm": "NODE_ENV=esm pnpm transpile --out-dir dist/esm --source-maps --out-file-extension .mjs",
    "package-types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "pnpm test-type && pnpm test-circular && pnpm test-linter",
    "test-circular": "pnpm depcruise --validate .dependency-cruiser.js .",
    "test-linter": "pnpm eslint .",
    "test-type": "tsc --noEmit --emitDeclarationOnly false",
    "transpile": "babel src --extensions .ts --quiet",
    "watch": "rm -rf dist && concurrently 'pnpm:package-* --watch'"
  },
  "dependencies": {
    "@hamstore/command-json-schema": "workspace:"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@hamstore/core": "workspace:",
    "@hamstore/event-type-json-schema": "workspace:",
    "@types/node": "^24.5.2",
    "babel-plugin-module-resolver": "^4.1.0",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.0.1",
    "eslint": "^9.36.0",
    "json-schema-to-ts": "^3.1.1",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "ts-toolbelt": "^9.6.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.2"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/esm/*.mjs",
      "require": "./dist/cjs/*.cjs",
      "default": "./dist/esm/*.mjs"
    }
  },
  "maintainers": [
    "Thomas Aribart",
    "Charles Géry",
    "Juliette Fournier",
    "Valentin Beggi",
    "Stanislas Hannebelle"
  ],
  "peerDependencies": {
    "@hamstore/core": "*",
    "@hamstore/event-type-json-schema": "*",
    "json-schema-to-ts": "^2.0.0 || ^3.0.0"
  }
}
